PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/grocery
DATABASE_SSL=false
API_KEY=dev-api-key-change-in-prod
NODE_ENV=development
REQUEST_LOGGING=false

# AI Kernel
ANTHROPIC_API_KEY=sk-ant-...
AI_KERNEL_MODEL=claude-sonnet-4-6

# USDA FoodData Central (register free at https://fdc.nal.usda.gov/)
# DEMO_KEY is rate-limited (1000 req/hr). Use a registered key in production.
USDA_API_KEY=DEMO_KEY

# Worker tuning
PLAN_WORKER_POLL_MS=2000
PLAN_WORKER_VERBOSE=false
